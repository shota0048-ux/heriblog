---
import type { MarkdownHeading } from 'astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'] & { headings?: MarkdownHeading[] };

const { title, description, pubDate, updatedDate, heroImage, category, headings } = Astro.props;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			.hero-banner {
				position: relative;
				width: 100%;
				height: 360px;
				overflow: hidden;
				background: var(--color-bg-soft);
			}
			.hero-banner :global(img) {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
			}
			.hero-banner::after {
				content: "";
				position: absolute;
				inset: 0;
				background: linear-gradient(180deg, rgba(20, 48, 74, 0) 50%, rgba(20, 48, 74, 0.35) 100%);
				pointer-events: none;
			}

			.article-wrap {
				max-width: 760px;
				margin: 0 auto;
				padding: 0 1.5em;
			}
			.article-header {
				padding: 2.5em 0 2em;
				text-align: center;
				border-bottom: 1px solid var(--color-border);
				margin-bottom: 2.5em;
			}
			.article-meta {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.8rem;
				font-size: 0.85rem;
				color: var(--color-text-muted);
				margin-bottom: 1em;
			}
			.article-category {
				color: var(--color-accent);
				font-weight: 600;
				background: rgba(182, 90, 59, 0.08);
				padding: 0.2rem 0.7rem;
				border-radius: 4px;
				font-size: 0.82rem;
				text-decoration: none;
				transition: background 0.15s;
			}
			.article-category:hover {
				background: rgba(182, 90, 59, 0.18);
			}
			.article-title {
				font-family: var(--font-serif);
				font-size: 2rem;
				color: var(--color-primary);
				margin: 0 0 0.3em;
				line-height: 1.4;
				letter-spacing: 0.01em;
			}
			.last-updated-on {
				font-size: 0.85rem;
				color: var(--color-text-muted);
				font-style: italic;
				margin-top: 0.5em;
			}

			.prose {
				color: var(--color-text);
				font-size: 1rem;
			}
			.prose :global(h2) {
				margin-top: 2.4em;
			}

			.full-main {
				max-width: none;
				padding: 0;
				width: 100%;
			}

			@media (max-width: 720px) {
				.hero-banner {
					height: 200px;
				}
				.article-wrap {
					padding: 0 1em;
				}
				.article-title {
					font-size: 1.35rem;
					letter-spacing: 0;
				}
				.article-header {
					padding: 1.5em 0 1.2em;
					margin-bottom: 1.5em;
				}
				.article-meta {
					font-size: 0.78rem;
					gap: 0.6rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main class="full-main">
			<article>
				{heroImage && (
					<div class="hero-banner">
						<Image width={1280} height={640} src={heroImage} alt="" />
					</div>
				)}
				<div class="article-wrap">
					<header class="article-header">
						<div class="article-meta">
							<FormattedDate date={pubDate} />
							{category && (
								<a href={`/blog/category/${category}/`} class="article-category">{category}</a>
							)}
						</div>
						<h1 class="article-title">{title}</h1>
						{updatedDate && (
							<div class="last-updated-on">
								Last updated on <FormattedDate date={updatedDate} />
							</div>
						)}
					</header>
					{headings && <TableOfContents headings={headings} />}
					<div class="prose">
						<slot />
					</div>
					<Comments />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
