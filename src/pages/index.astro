---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 5);

const categories = ['飛行記録', '機体解説', '航空事故解説', '資格・訓練'];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.hero {
				margin-bottom: 3rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid #eee;
			}
			.hero h1 {
				font-size: 2rem;
				margin-bottom: 0.5rem;
			}
			.hero p {
				color: #666;
				font-size: 1rem;
				line-height: 1.7;
			}
			.categories {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin: 1.5rem 0;
			}
			.category-tag {
				background: #f0f4f8;
				border-radius: 4px;
				padding: 0.3rem 0.8rem;
				font-size: 0.85rem;
				color: #333;
				text-decoration: none;
			}
			.category-tag:hover {
				background: #d0e0f0;
			}
			.recent h2 {
				font-size: 1.2rem;
				margin-bottom: 1rem;
				color: #333;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				padding: 1rem 0;
				border-bottom: 1px solid #f0f0f0;
			}
			.post-list a {
				text-decoration: none;
				color: inherit;
			}
			.post-list a:hover .post-title {
				color: #2563eb;
			}
			.post-title {
				font-size: 1.05rem;
				font-weight: 600;
				margin: 0 0 0.25rem;
			}
			.post-meta {
				font-size: 0.8rem;
				color: #888;
				display: flex;
				gap: 0.75rem;
			}
			.post-category {
				color: #2563eb;
				font-weight: 500;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>ヘリブログ</h1>
				<p>現役ヘリコプターパイロットが書く航空ブログです。<br>飛行の現場から、機体のこと、事故の教訓、訓練のことまで。</p>
				<div class="categories">
					{categories.map(cat => (
						<span class="category-tag">{cat}</span>
					))}
				</div>
			</div>
			<div class="recent">
				<h2>最新の記事</h2>
				<ul class="post-list">
					{posts.map(post => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<p class="post-title">{post.data.title}</p>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
									{post.data.category && <span class="post-category">{post.data.category}</span>}
								</div>
							</a>
						</li>
					))}
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>
