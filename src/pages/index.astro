---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 6);

const categories = ['飛行記録', '機体解説', '航空事故解説', '資格・訓練', '最近の変更点', 'ニュース', '航空業界', '基礎知識', 'そのほか'];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
				color: #fff;
				padding: 4rem 1.5rem 5rem;
				text-align: center;
				position: relative;
				overflow: hidden;
			}
			.hero::before {
				content: "";
				position: absolute;
				inset: 0;
				background-image:
					radial-gradient(circle at 20% 80%, rgba(182, 90, 59, 0.15), transparent 50%),
					radial-gradient(circle at 80% 20%, rgba(216, 130, 94, 0.1), transparent 50%);
				pointer-events: none;
			}
			.hero-inner {
				max-width: 720px;
				margin: 0 auto;
				position: relative;
			}
			.hero h1 {
				font-family: var(--font-serif);
				color: #fff;
				font-size: 2.6rem;
				margin: 0 0 0.4em;
				letter-spacing: 0.05em;
			}
			.hero-mark {
				color: var(--color-accent-soft);
				display: inline-block;
				transform: rotate(-15deg);
				margin-right: 0.2em;
			}
			.hero p {
				color: rgba(255, 255, 255, 0.85);
				font-size: 1.05rem;
				line-height: 1.9;
				max-width: 540px;
				margin: 0 auto;
			}

			main {
				max-width: 1080px;
				margin: 0 auto;
				padding: 3rem 1.5rem 2rem;
			}
			.section-title {
				font-family: var(--font-serif);
				font-size: 1.4rem;
				color: var(--color-primary);
				margin: 0 0 0.3em;
				display: flex;
				align-items: baseline;
				gap: 0.6em;
			}
			.section-title::after {
				content: "";
				flex: 1;
				height: 1px;
				background: var(--color-border);
			}
			.section-sub {
				color: var(--color-text-muted);
				font-size: 0.9rem;
				margin: 0 0 2rem;
			}
			.categories {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 3rem;
			}
			.category-tag {
				background: var(--color-surface);
				border: 1px solid var(--color-border);
				border-radius: 999px;
				padding: 0.4rem 0.95rem;
				font-size: 0.85rem;
				color: var(--color-text-soft);
				font-weight: 500;
				text-decoration: none;
				transition: border-color 0.15s, color 0.15s;
			}
			.category-tag:hover {
				border-color: var(--color-accent);
				color: var(--color-accent);
			}

			.post-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1.8rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-card {
				background: var(--color-surface);
				border: 1px solid var(--color-border);
				border-radius: 12px;
				overflow: hidden;
				transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
			}
			.post-card a {
				display: block;
				text-decoration: none;
				color: inherit;
				height: 100%;
			}
			.post-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--shadow-lg);
				border-color: var(--color-accent-soft);
			}
			.post-card.no-image {
				background: linear-gradient(135deg, #ffffff 0%, var(--color-bg-soft) 100%);
				border-left: 4px solid var(--color-accent);
			}
			.post-card.no-image .card-body {
				padding: 1.4rem 1.4rem 1.5rem;
			}
			.card-image-wrap {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: var(--color-bg-soft);
			}
			.card-image-wrap :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				display: block;
				transition: transform 0.4s ease;
			}
			.post-card:hover .card-image-wrap :global(img) {
				transform: scale(1.05);
			}
			.card-image-placeholder {
				width: 100%;
				height: 100%;
				display: flex;
				align-items: center;
				justify-content: center;
				background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
				color: var(--color-accent-soft);
				font-size: 3rem;
			}
			.card-body {
				padding: 1.2rem 1.4rem 1.5rem;
			}
			.card-meta {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				font-size: 0.78rem;
				color: var(--color-text-muted);
				margin-bottom: 0.6rem;
			}
			.card-category {
				color: var(--color-accent);
				font-weight: 600;
				background: rgba(182, 90, 59, 0.08);
				padding: 0.15rem 0.55rem;
				border-radius: 4px;
			}
			.card-title {
				font-family: var(--font-serif);
				font-size: 1.05rem;
				font-weight: 700;
				color: var(--color-primary);
				margin: 0 0 0.6rem;
				line-height: 1.5;
			}
			.card-desc {
				font-size: 0.88rem;
				color: var(--color-text-soft);
				line-height: 1.7;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.see-all {
				text-align: center;
				margin: 2.5rem 0 1rem;
			}
			.see-all-link {
				display: inline-block;
				padding: 0.7em 1.8em;
				background: var(--color-primary);
				color: #fff;
				text-decoration: none;
				border-radius: 999px;
				font-size: 0.95rem;
				font-weight: 500;
				transition: background 0.2s;
			}
			.see-all-link:hover {
				background: var(--color-accent);
				color: #fff;
			}

			@media (max-width: 720px) {
				.hero {
					padding: 2.2rem 1rem 2.5rem;
				}
				.hero h1 {
					font-size: 1.8rem;
				}
				.hero p {
					font-size: 0.9rem;
					line-height: 1.7;
				}
				.hero-stat-value {
					font-size: 18px;
				}
				main {
					padding: 1.8rem 1rem 1rem;
				}
				.post-grid {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
				.card-image-wrap {
					aspect-ratio: 21 / 9;
				}
				.card-body {
					padding: 0.9rem 1.1rem 1.1rem;
				}
				.card-title {
					font-size: 0.98rem;
				}
				.card-desc {
					font-size: 0.83rem;
					-webkit-line-clamp: 2;
				}
				.section-title {
					font-size: 1.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<section class="hero">
			<div class="hero-inner">
				<h1><span class="hero-mark">✈</span>ヘリブログ</h1>
				<p>現役ヘリコプターパイロットが書く航空ブログ。<br />飛行の現場から、機体のこと、事故の教訓、訓練のことまで。</p>
			</div>
		</section>
		<main>
			<h2 class="section-title">カテゴリ</h2>
			<p class="section-sub">関心のあるテーマからどうぞ</p>
			<div class="categories">
				{categories.map(cat => (
					<a href={`/blog/category/${cat}/`} class="category-tag">{cat}</a>
				))}
			</div>

			<h2 class="section-title">最新の記事</h2>
			<p class="section-sub">直近の更新</p>
			<ul class="post-grid">
				{posts.map(post => (
					<li class={`post-card${post.data.heroImage ? '' : ' no-image'}`}>
						<a href={`/blog/${post.id}/`}>
							{post.data.heroImage && (
								<div class="card-image-wrap">
									<Image src={post.data.heroImage} alt="" width={600} height={338} />
								</div>
							)}
							<div class="card-body">
								<div class="card-meta">
									<FormattedDate date={post.data.pubDate} />
									{post.data.category && <span class="card-category">{post.data.category}</span>}
								</div>
								<p class="card-title">{post.data.title}</p>
								<p class="card-desc">{post.data.description}</p>
							</div>
						</a>
					</li>
				))}
			</ul>

			<div class="see-all">
				<a href="/blog" class="see-all-link">すべての記事を見る →</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
